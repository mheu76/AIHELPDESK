ENVIRONMENT=development
DEBUG=true

LLM_PROVIDER=claude
ANTHROPIC_API_KEY=dummy-dev-key
OPENAI_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7

DATABASE_URL=postgresql+asyncpg://helpdesk:helpdesk@db:5432/helpdesk
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=it_knowledge_base

JWT_SECRET_KEY=change-this-docker-dev-secret-key-to-a-long-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=["http://localhost:3000"]

LOG_LEVEL=INFO
LOG_FORMAT=human

APP_NAME=IT Helpdesk API
APP_VERSION=1.0.0
MAX_CONVERSATION_TURNS=10
RAG_TOP_K=3
