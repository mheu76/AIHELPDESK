# Environment
ENVIRONMENT=development
DEBUG=true

# LLM Configuration
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=
GEMINI_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7

# Database
DATABASE_URL=postgresql+asyncpg://helpdesk:password@localhost:5432/helpdesk
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=it_knowledge_base

# Authentication (Generate a secure key with: openssl rand -hex 32)
JWT_SECRET_KEY=your-super-secret-key-min-32-characters-required-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=["http://localhost:3000"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=human

# Application
APP_NAME=IT Helpdesk API
APP_VERSION=1.0.0
MAX_CONVERSATION_TURNS=10
RAG_TOP_K=3
